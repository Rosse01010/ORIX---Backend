# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change_me_in_production

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ORIX_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/ORIX_DB

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ─── Redis Streams ─────────────────────────────────────────────────────────────
STREAM_FRAMES=stream:frames
STREAM_VECTORS=stream:vectors
STREAM_EVENTS=stream:events
STREAM_MAX_LEN=1000

# ─── Cameras ───────────────────────────────────────────────────────────────────
# Comma-separated: 0  (USB device index)  or  rtsp://user:pass@ip:554/stream
CAMERA_SOURCES=0
CAMERA_FRAME_RATE=15
CAMERA_RESIZE_WIDTH=640
CAMERA_RESIZE_HEIGHT=480

# ─── AI Models ─────────────────────────────────────────────────────────────────
DETECTOR_BACKEND=insightface
EMBEDDER_BACKEND=arcface
MODEL_DIR=/app/models
# buffalo_l  = SCRFD-10G detector + ArcFace R100  (best accuracy, recommended)
# buffalo_m  = SCRFD-5G  + ArcFace R50            (balanced speed/accuracy)
# buffalo_s  = SCRFD-500M + MBF                   (fastest, lower accuracy)
INSIGHTFACE_MODEL=buffalo_l

# ─── Recognition thresholds ────────────────────────────────────────────────────
# ArcFace (Deng et al., CVPR 2019) produces 512-dim L2-normalised embeddings.
# Similarity is cosine similarity ∈ [-1, 1] — HIGHER = more similar.
#
#  ≥ 0.55  → confident match       (frontal, good lighting)
#  0.40–0.54 → probable match      (off-axis, partial occlusion, age gap)
#              → always surface candidate panel for operator review
#  0.30–0.39 → weak / uncertain    → show candidates only, never auto-identify
#  < 0.30   → different identity
#
# Cross-pose similarity data from VGGFace2 (Cao et al., 2018):
#   front-to-profile pairs average ~0.49 even for the best models,
#   so for crowd/CCTV scenarios 0.40 is the recommended lower bound.
#
# SIMILARITY_THRESHOLD — minimum cosine similarity to auto-identify a face.
#   0.40 = multi-angle / crowds (catches side profiles but more false positives)
#   0.55 = strict frontal-only  (lower false accept rate)
SIMILARITY_THRESHOLD=0.40

# MIN_FACE_SIZE — minimum face bounding-box side (pixels) before embedding.
#   Smaller values detect more faces in crowds but increase noise.
MIN_FACE_SIZE=20

# DETECTION_CONFIDENCE — SCRFD detector score threshold.
#   Lower = more detections in difficult conditions (occlusion, low light).
DETECTION_CONFIDENCE=0.50

# CANDIDATE_MIN_SIM — minimum cosine similarity for a person to appear in the
#   candidate panel when a face is Unknown or off-axis.
#   0.30 is a safe lower bound: ArcFace negative pairs rarely exceed 0.35
#   even under large pose variation (see Figure 7 in ArcFace paper).
CANDIDATE_MIN_SIM=0.30

# CANDIDATE_YAW_THRESHOLD — |yaw| degrees above which candidates are shown
#   even when a face WAS recognised (guards against off-axis false accepts).
CANDIDATE_YAW_THRESHOLD=30

# ─── GPU ───────────────────────────────────────────────────────────────────────
GPU_DEVICE_ID=0
USE_GPU=true
ONNX_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# ─── Workers ───────────────────────────────────────────────────────────────────
GPU_WORKER_BATCH_SIZE=4
GPU_WORKER_TIMEOUT_MS=100
DB_WORKER_BATCH_SIZE=8
WORKER_LOG_LEVEL=INFO
