# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change_me_in_production

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ORIX_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/ORIX_DB

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ─── Redis Streams ─────────────────────────────────────────────────────────────
STREAM_FRAMES=stream:frames
STREAM_VECTORS=stream:vectors
STREAM_EVENTS=stream:events
STREAM_MAX_LEN=1000

# ─── Cameras ───────────────────────────────────────────────────────────────────
# Comma-separated list of camera sources
# RTSP: rtsp://user:pass@192.168.1.10:554/stream
# USB:  0, 1, 2  (device index)
CAMERA_SOURCES=0
CAMERA_FRAME_RATE=15
CAMERA_RESIZE_WIDTH=640
CAMERA_RESIZE_HEIGHT=480

# ─── AI Models ─────────────────────────────────────────────────────────────────
# insightface | mediapipe
DETECTOR_BACKEND=insightface
# arcface | facenet
EMBEDDER_BACKEND=arcface
MODEL_DIR=/app/models
# ArcFace model variant: buffalo_l | buffalo_m | buffalo_s
INSIGHTFACE_MODEL=buffalo_l

# ─── Recognition ───────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.45
MIN_FACE_SIZE=20
DETECTION_CONFIDENCE=0.85

# ─── GPU ───────────────────────────────────────────────────────────────────────
GPU_DEVICE_ID=0
USE_GPU=true
ONNX_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# ─── Workers ───────────────────────────────────────────────────────────────────
GPU_WORKER_BATCH_SIZE=4
GPU_WORKER_TIMEOUT_MS=100
DB_WORKER_BATCH_SIZE=8
WORKER_LOG_LEVEL=INFO
